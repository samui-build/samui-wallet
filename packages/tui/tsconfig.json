{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "lib": ["ESNext"],
    "module": "Preserve",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "target": "ESNext"
  },
  "exclude": ["node_modules", "dist"],
  "extends": "@workspace/config-typescript/react-library.json",
  "include": ["src"]
}
